{
  "name": "@teyou/openclaw-googlechatpubsub",
  "version": "0.5.4",
  "description": "OpenClaw channel plugin — listen to Google Chat spaces via Workspace Events + Pub/Sub. No @mention required. Multi-agent routing with keyword and alwaysListen support.",
  "type": "module",
  "main": "index.ts",
  "license": "MIT",
  "author": "",
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "openclaw-channel",
    "google-chat",
    "google-workspace",
    "pubsub",
    "workspace-events",
    "multi-agent",
    "ai-agent",
    "chatbot"
  ],
  "files": [
    "index.ts",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "openclaw": "*"
  },
  "publishConfig": {
    "access": "public"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "channel": {
      "id": "googlechatpubsub",
      "label": "Google Chat (Pub/Sub)",
      "blurb": "Passive Google Chat listening via Workspace Events + Pub/Sub — no @mention required."
    },
    "compat": {
      "pluginApi": "1",
      "pluginApiRange": ">=1",
      "builtWithOpenClawVersion": "2026.3.28",
      "minGatewayVersion": "2026.3.22"
    },
    "build": {
      "openclawVersion": "2026.3.28"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/teyou/openclaw-googlechatpubsub-plugin.git"
  },
  "homepage": "https://teyou.github.io/openclaw-googlechatpubsub-plugin/",
  "bugs": {
    "url": "https://github.com/teyou/openclaw-googlechatpubsub-plugin/issues"
  }
}
